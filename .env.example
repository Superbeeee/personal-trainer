# ── 複製成 .env 並填好（python-dotenv 會自動載入，不用手動 source）──

# ===== 必填 =====

# 1) Telegram bot token（跟 @BotFather 申請，見 README 步驟一）
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJklmNOpqrs

# 2) 只允許你自己用：你的 Telegram 數字 ID（見 README 步驟二）
#    填 0 = 不限制（不建議，等於誰加都能用、還能驅動你本機的 claude）
ALLOWED_TELEGRAM_USER_ID=0

# 3) claude 執行檔真實路徑（claude 多半是 shell alias，subprocess 認不得）
#    用 `which claude` 看 alias 指到哪；mac 裝 native build 通常是下面這個
CLAUDE_BIN=/Users/superbeeee/.claude/local/claude

# 4) 權限模式：acceptEdits=自動讀寫檔案、不跑任意 Bash（建議）
#    要讓教練也能跑指令就改成 bypassPermissions（風險自負）
PERMISSION_MODE=acceptEdits

# 5) 單次回覆逾時秒數（教練若要跑工具會花點時間）
CLAUDE_TIMEOUT=300

# 6) 免詢問就放行的工具。讀寫檔案已由 acceptEdits 放行，這裡額外開放：
#    Bash(git:*) = 讓教練能依要求 push 訓練紀錄到 GitHub（只放行 git，安全）
#    要再接 MCP（如 Notion）可空白分隔：例如 "Bash(git:*) mcp__notion"
ALLOWED_TOOLS=Bash(git:*)

# 7) session 閒置自動重開（分鐘）：超過這時間沒講話，下一則就開新 session
#    省 token。設 0 = 永不自動重開（維持同一條對話直到 /new）
#    想最省 token、每則都全新（教練不記得上一則）→ 設很小如 0.1
SESSION_IDLE_MINUTES=30

# 8) 教練資料夾：裡面有 CLAUDE.md + logs/，訓練紀錄寫在這
#    不設 = 用專案內建的 coach/ 子資料夾（絕對路徑，跟啟動目錄無關，建議）
#    要自訂請填「絕對路徑」，相對路徑會依啟動時所在目錄解析、容易出錯
#COACH_DIR=/path/to/coach

# 9) 模型：留空=用 Claude Code 預設；要指定就填 opus 或 claude-opus-4-8
CLAUDE_MODEL=
